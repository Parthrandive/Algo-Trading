# NSE Official API Credentials (Primary)
NSE_API_BASE_URL="https://www.nseindia.com/api"
NSE_API_KEY=""
NSE_API_SECRET=""

# Broker API Credentials (Secondary)
BROKER_NAME="zerodha" # or upstox, angelone
BROKER_API_KEY=""
BROKER_API_SECRET=""
BROKER_ACCESS_TOKEN=""

# System Config
ENV="development" # development, staging, production
LOG_LEVEL="INFO"
TIMEZONE="Asia/Kolkata"

# Storage Paths (Optional overrides)
DATA_DIR="./data"

# Database Config
# For local host execution connecting to Docker DB:
DATABASE_URL="postgresql://sentinel:sentinel@localhost:5432/sentinel_db"
# For execution INSIDE the app container:
# DATABASE_URL="postgresql://sentinel:sentinel@sentinel-db:5432/sentinel_db"
